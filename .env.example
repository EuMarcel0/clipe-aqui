# Supabase (Vite usa prefixo VITE_)
VITE_SUPABASE_URL=https://egupwrwzcuqazlshhfoq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Secrets das Edge Functions (Dashboard > Edge Functions > Secrets)
# OPENAI_API_KEY=sk-...
#
# Storage (bucket público "clips"):
# AWS_S3_BUCKET=clips
# AWS_S3_PUBLIC_BASE_URL=https://egupwrwzcuqazlshhfoq.supabase.co/storage/v1/object/public/clips
#
# NÃO use o endpoint /storage/v1/s3 aqui — isso quebra o player.
# Se estiver errado, pode remover: a function usa getPublicUrl automaticamente.
# Opcionais (só se for usar protocolo S3 externo; get-upload-url atual NÃO precisa):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# já são injetados automaticamente pelo runtime das Edge Functions.
