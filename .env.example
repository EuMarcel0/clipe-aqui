# Supabase (Vite usa prefixo VITE_)
VITE_SUPABASE_URL=https://egupwrwzcuqazlshhfoq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# URL pública do app (local / Vercel) — usada no redirect do Google OAuth
VITE_APP_URL=http://localhost:5173

# URL pública do R2 (sem secrets)
VITE_R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# -----------------------------------------------------------------------------
# Google OAuth — NÃO vão no Vite.
# Cole no Supabase Dashboard → Authentication → Providers → Google
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
#
# No Google Cloud Console → Credentials → OAuth 2.0 Client:
# Authorized JavaScript origins:
#   http://localhost:5173
#   https://clipe-aqui.vercel.app
# Authorized redirect URIs (Supabase, não o Vite):
#   https://egupwrwzcuqazlshhfoq.supabase.co/auth/v1/callback
#
# No Supabase → Authentication → URL Configuration:
# Site URL: http://localhost:5173 (prod: https://clipe-aqui.vercel.app)
# Redirect URLs:
#   http://localhost:5173/**
#   http://localhost:5173/auth/callback
#   https://clipe-aqui.vercel.app/**
#   https://clipe-aqui.vercel.app/auth/callback

# Secrets das Edge Functions (Dashboard > Edge Functions > Secrets)
# OPENAI_API_KEY=sk-...
#
# -----------------------------------------------------------------------------
# Cloudflare R2 (Edge Functions — NÃO use VITE_ para keys/secrets)
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=83584aa03a17378a9263b52d3f36f9ca
# R2_ENDPOINT=https://83584aa03a17378a9263b52d3f36f9ca.r2.cloudflarestorage.com
# R2_BUCKET=clipe-aqui-clips
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
#
# No frontend (.env Vite), só a URL pública:
# VITE_R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
#
# Deploy:
#   npx supabase functions deploy get-upload-url
#
# -----------------------------------------------------------------------------
# Stripe (Edge Functions secrets — NÃO vão no Vite)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PACK_10=price_...
# STRIPE_PRICE_PACK_20=price_...
# STRIPE_PRICE_PACK_50=price_...
# STRIPE_PRICE_PACK_100=price_...
#
# Webhook endpoint (Stripe Dashboard → Developers → Webhooks):
#   https://egupwrwzcuqazlshhfoq.supabase.co/functions/v1/stripe-webhook
# Eventos: checkout.session.completed
#
# Deploy das functions:
#   supabase functions deploy create-checkout
#   supabase functions deploy stripe-webhook
#
# SQL: rode supabase/migrations/003_billing.sql no SQL Editor
