# Supabase (Vite usa prefixo VITE_)
VITE_SUPABASE_URL=https://egupwrwzcuqazlshhfoq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# URL pública do app (local / Vercel) — usada no redirect do Google OAuth
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Google OAuth — NÃO vão no Vite.
# Cole no Supabase Dashboard → Authentication → Providers → Google
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
#
# No Google Cloud Console → Credentials → OAuth 2.0 Client:
# Authorized JavaScript origins:
#   http://localhost:5173
#   https://clipe-aqui.vercel.app
# Authorized redirect URIs (Supabase, não o Vite):
#   https://egupwrwzcuqazlshhfoq.supabase.co/auth/v1/callback
#
# No Supabase → Authentication → URL Configuration:
# Site URL: http://localhost:5173 (prod: https://clipe-aqui.vercel.app)
# Redirect URLs:
#   http://localhost:5173/**
#   http://localhost:5173/auth/callback
#   https://clipe-aqui.vercel.app/**
#   https://clipe-aqui.vercel.app/auth/callback

# Secrets das Edge Functions (Dashboard > Edge Functions > Secrets)
# OPENAI_API_KEY=sk-...
#
# Storage (bucket público "clips"):
# AWS_S3_BUCKET=clips
# AWS_S3_PUBLIC_BASE_URL=https://egupwrwzcuqazlshhfoq.supabase.co/storage/v1/object/public/clips
